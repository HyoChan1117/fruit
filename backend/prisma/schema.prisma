generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// Singleton row: application code always reads/writes id = 1.
model CompanyInfo {
  id                 Int      @id @default(1)
  introText          String
  address            String
  nearbyInfo         String?
  parkingInfo        String?
  latitude           Float?
  longitude          Float?
  heroHeadline       String   @default("가장 신선한 순간을,\n선별합니다.")
  heroSubcopy        String   @default("구천청과는 엄격한 기준으로 선별한 농산물을 산지에서 식탁까지 정직하게 전달하는 선과장입니다.")
  heroTypewriterText String   @default("FRESH · SELECTED · DELIVERED")
  businessHours      String?
  holidays           String?
  auctionTime        String?
  serviceIntroTitle  String   @default("어떤 서비스를 제공할까?")
  serviceIntroIcon   String   @default("🍎")
  valueCard1Title    String   @default("산지 직송")
  valueCard1Body     String   @default("전국 산지에서 엄선한 신선 청과를 매일 직송으로 받아 최상의 상태를 유지합니다.")
  valueCard1Icon     String   @default("🚚")
  valueCard2Title    String   @default("투명한 경매")
  valueCard2Body     String   @default("신속하고 투명한 경매 진행으로 합리적인 가격을 보장합니다.")
  valueCard2Icon     String   @default("📊")
  valueCard3Title    String   @default("철저한 품질 검수")
  valueCard3Body     String   @default("입고 단계부터 꼼꼼하게 검수하여 믿을 수 있는 품질만 선별합니다.")
  valueCard3Icon     String   @default("🔍")
  valueCard4Title    String   @default("신속한 사후 관리")
  valueCard4Body     String   @default("주문 후 문의와 요청에 빠르게 응대하여 끝까지 책임지고 관리합니다.")
  valueCard4Icon     String   @default("💬")
  serviceCtaTitle    String   @default("구천청과가 궁금하다면")
  aboutText          String?
  aboutImageUrl      String?
  pageBannerImageUrl String?
  popupBannerEnabled Boolean  @default(false)
  popupBannerImageUrl String?
  popupBannerLinkUrl String?
  updatedAt          DateTime @updatedAt
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  imageUrl  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  variety     String
  description String
  imageUrl    String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  caption   String?
  createdAt DateTime @default(now())
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuctionResult {
  id          Int      @id @default(autoincrement())
  auctionDate DateTime
  ownerName   String
  productName String
  variety     String
  grade       String
  weight      Float
  quantity    Int
  unitPrice   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
